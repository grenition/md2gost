APP_ENV=production
GATEWAY_PORT=80

# Internal service URLs (keep defaults unless network layout differs)
DOCX_SERVICE_URL=http://docx-service:5000
FILE_SERVICE_URL=http://file-service:5002
SESSION_SERVICE_URL=http://session-service:5003

# Session and image storage backends
SESSION_STORE_BACKEND=postgres
STORAGE_BACKEND=s3
DATABASE_URL=postgresql://md2gost:md2gost@postgres:5432/md2gost
POSTGRES_DB=md2gost
POSTGRES_USER=md2gost
POSTGRES_PASSWORD=md2gost
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=md2gost-sessions
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=0

# Converter runtime
WORKING_DIR=/tmp/md2gost
SESSIONS_STORAGE_BASE=/tmp/md2gost/sessions
TEMPLATE_PATH=/app/md2gost/Template.docx
